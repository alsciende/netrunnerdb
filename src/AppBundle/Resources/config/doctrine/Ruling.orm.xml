<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="AppBundle\Repository\RulingRepository" name="AppBundle\Entity\Ruling" table="ruling">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="dateCreation" type="datetime" column="date_creation"/>
    <field name="dateUpdate" type="datetime" column="date_update"/>
    <field name="rawtext" type="text" column="rawtext" nullable="false"/>
    <field name="text" type="text" column="text" nullable="false"/>
    <field name="nsg_rules_team_verified" type="boolean" column="nsg_rules_team_verified" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <many-to-one field="card" target-entity="AppBundle\Entity\Card" inversed-by="rulings" fetch="LAZY">
      <join-columns>
        <join-column name="card_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="user" target-entity="AppBundle\Entity\User" fetch="LAZY">
      <join-columns>
        <join-column name="user_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
