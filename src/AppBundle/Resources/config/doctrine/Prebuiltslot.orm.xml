<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="AppBundle\Entity\Prebuiltslot" table="prebuiltslot">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="quantity" type="smallint" column="quantity"/>
    <many-to-one field="prebuilt" target-entity="AppBundle\Entity\Prebuilt" inversed-by="slots" fetch="LAZY">
      <join-columns>
        <join-column name="prebuilt_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="card" target-entity="AppBundle\Entity\Card" fetch="LAZY">
      <join-columns>
        <join-column name="card_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
