<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="AppBundle\Entity\Prebuilt" table="prebuilt">
    <indexes>
      <index name="prebuilt_date_release_index" columns="date_release"/>
      <index name="prebuilt_position_index" columns="position"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="code" type="string" column="code" length="50" unique="true"/>
    <field name="name" type="string" column="name" length="255"/>
    <field name="dateRelease" type="date" column="date_release" nullable="true"/>
    <field name="position" type="smallint" column="position" nullable="false"/>
    <field name="dateCreation" type="datetime" column="date_creation" nullable="false"/>
    <field name="dateUpdate" type="datetime" column="date_update" nullable="false"/>
    <one-to-many field="slots" target-entity="AppBundle\Entity\Prebuiltslot" mapped-by="prebuilt" fetch="LAZY">
      <cascade>
        <cascade-remove/>
        <cascade-persist/>
        <cascade-detach/>
      </cascade>
    </one-to-many>
    <many-to-one field="side" target-entity="AppBundle\Entity\Side" fetch="LAZY">
      <join-columns>
        <join-column name="side_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="identity" target-entity="AppBundle\Entity\Card" fetch="LAZY">
      <join-columns>
        <join-column name="identity_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="faction" target-entity="AppBundle\Entity\Faction" fetch="LAZY">
      <join-columns>
        <join-column name="faction_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
