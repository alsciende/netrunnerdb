<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="AppBundle\Repository\PackRepository" name="AppBundle\Entity\Pack" table="pack">
    <indexes>
      <index name="date_release_index" columns="date_release"/>
      <index name="position_index" columns="position"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="code" type="string" column="code" length="10" unique="true"/>
    <field name="name" type="string" column="name" length="255"/>
    <field name="dateRelease" type="date" column="date_release" nullable="true"/>
    <field name="size" type="smallint" column="size" nullable="true"/>
    <field name="ffgId" type="integer" column="ffg_id" nullable="true"/>
    <field name="position" type="smallint" column="position" nullable="false"/>
    <field name="dateCreation" type="datetime" column="date_creation" nullable="false"/>
    <field name="dateUpdate" type="datetime" column="date_update" nullable="false"/>
    <one-to-many field="cards" target-entity="AppBundle\Entity\Card" mapped-by="pack" fetch="EXTRA_LAZY">
      <order-by>
        <order-by-field name="position" direction="ASC"/>
      </order-by>
    </one-to-many>
    <one-to-many field="decklists" target-entity="AppBundle\Entity\Decklist" mapped-by="lastPack" fetch="LAZY"/>
    <many-to-one field="cycle" target-entity="AppBundle\Entity\Cycle" inversed-by="packs" fetch="LAZY">
      <join-columns>
        <join-column name="cycle_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
