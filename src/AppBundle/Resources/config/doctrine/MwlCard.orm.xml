<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="AppBundle\Entity\MwlCard" table="mwl_card">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="mwl_id" type="integer" column="mwl_id"/>
    <field name="card_id" type="integer" column="card_id"/>
    <field name="global_penalty" type="integer" column="global_penalty" nullable="true"/>
    <field name="universal_faction_cost" type="integer" column="universal_faction_cost" nullable="true"/>
    <field name="is_restricted" type="boolean" column="is_restricted" nullable="true"/>
    <field name="is_banned" type="boolean" column="is_banned" nullable="true"/>
    <many-to-one field="mwl" target-entity="AppBundle\Entity\Mwl" fetch="LAZY">
      <join-columns>
        <join-column name="mwl_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="card" target-entity="AppBundle\Entity\Card" fetch="LAZY">
      <join-columns>
        <join-column name="card_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
