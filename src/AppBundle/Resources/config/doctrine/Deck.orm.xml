<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="AppBundle\Entity\Deck" table="deck">
    <indexes>
      <index name="date_update_index" columns="date_update"/>
    </indexes>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="uuid" type="string" column="uuid" length="36" unique="true" nullable="true"/>
    <field name="name" type="string" column="name" length="255"/>
    <field name="dateCreation" type="datetime" column="date_creation"/>
    <field name="dateUpdate" type="datetime" column="date_update"/>
    <field name="description" type="text" column="description" nullable="true"/>
    <field name="problem" type="string" column="problem" length="20" nullable="true"/>
    <field name="deckSize" type="smallint" column="deck_size" nullable="true"/>
    <field name="influenceSpent" type="smallint" column="influence_spent" nullable="true"/>
    <field name="agendaPoints" type="smallint" column="agenda_points" nullable="true"/>
    <field name="tags" type="string" column="tags" length="4000" nullable="true"/>
    <one-to-many field="slots" target-entity="AppBundle\Entity\Deckslot" mapped-by="deck" fetch="LAZY">
      <cascade>
        <cascade-remove/>
        <cascade-persist/>
      </cascade>
    </one-to-many>
    <one-to-many field="children" target-entity="AppBundle\Entity\Decklist" mapped-by="parent" fetch="EXTRA_LAZY">
      <order-by>
        <order-by-field name="dateCreation" direction="DESC"/>
      </order-by>
    </one-to-many>
    <one-to-many field="changes" target-entity="AppBundle\Entity\Deckchange" mapped-by="deck" fetch="LAZY">
      <cascade>
        <cascade-remove/>
        <cascade-persist/>
      </cascade>
      <order-by>
        <order-by-field name="dateCreation" direction="DESC"/>
      </order-by>
    </one-to-many>
    <many-to-one field="user" target-entity="AppBundle\Entity\User" inversed-by="decks" fetch="LAZY">
      <join-columns>
        <join-column name="user_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="mwl" target-entity="AppBundle\Entity\Mwl" fetch="LAZY">
      <join-columns>
        <join-column name="mwl_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="side" target-entity="AppBundle\Entity\Side" inversed-by="decks" fetch="LAZY">
      <join-columns>
        <join-column name="side_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="identity" target-entity="AppBundle\Entity\Card" fetch="LAZY">
      <join-columns>
        <join-column name="identity_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="lastPack" target-entity="AppBundle\Entity\Pack" fetch="LAZY">
      <join-columns>
        <join-column name="last_pack_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="parent" target-entity="AppBundle\Entity\Decklist" inversed-by="children" fetch="LAZY">
      <join-columns>
        <join-column name="parent_decklist_id" referenced-column-name="id"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
